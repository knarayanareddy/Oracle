{
  "name": "oracle",
  "version": "1.0.0",
  "private": true,
  "description": "ORACLE — Swarm Intelligence Broker. We don't predict markets. We simulate the humans that move them.",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @oracle/web dev",
    "build": "pnpm --filter @oracle/web build",
    "preview": "pnpm --filter @oracle/web preview",
    "typecheck": "pnpm --filter @oracle/web typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:rls": "echo 'Run: supabase db reset && supabase test db' && exit 0",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "gen:types": "supabase gen types typescript --local --schema public,oracle_portfolio,oracle_simulation,oracle_signals,oracle_strategy,oracle_memory,oracle_autopilot,oracle_feed,oracle_audit > apps/web/src/types/database.types.ts"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "typescript": "^5.6.2"
  }
}
