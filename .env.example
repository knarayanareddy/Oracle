# ════════════════════════════════════════════════════════════════
# ORACLE — Environment Variable Registry (Addendum D)
# Copy to .env.local and fill all values. NEVER commit .env.local.
# ════════════════════════════════════════════════════════════════

# ── Supabase (Frankfurt EU region — eu-central-1) ─────────────
SUPABASE_URL=https://[project].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...       # Edge Functions + FastAPI ONLY
SUPABASE_JWT_SECRET=...

# ── LLM Providers ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...                  # GPT-4o + Whisper + Embeddings
QWEN_API_KEY=...                       # Simulation agents (cost saving)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ── Market Data ────────────────────────────────────────────────
ALPHA_VANTAGE_API_KEY=...              # L1 mid-tier data (free, 25 req/day)
POLYGON_API_KEY=...                    # L1 enterprise data (institutional grade)
POLYGON_BASE_URL=https://api.polygon.io
MARKET_DATA_PROVIDER=auto              # auto → polygon > alphavantage > yfinance
MARKET_DATA_CACHE_TTL=60               # seconds
FRED_API_KEY=...                       # L2 macro signals

# ── News & Prediction Markets ──────────────────────────────────
NEWS_API_KEY=...                       # L3 news feed
POLYMARKET_API_URL=https://gamma-api.polymarket.com  # L5 REST (no key)
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws  # L5 real-time

# ── Resilience (circuit breakers + retry) ──────────────────────
LLM_CIRCUIT_FAILURE_THRESHOLD=5
LLM_CIRCUIT_COOLDOWN_SECONDS=30
LLM_MAX_RETRIES=2

# ── Voice ──────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...                 # TTS voice (Phase 2)

# ── Memory ─────────────────────────────────────────────────────
ZEP_API_KEY=...                        # Zep Cloud memory (or local)
ZEP_API_URL=https://api.getzep.com

# ── Demo Mode ──────────────────────────────────────────────────
NEXT_PUBLIC_DEMO_USER_ID=00000000-0000-0000-0000-000000000001
NEXT_PUBLIC_DEMO_MODE=true             # Enable demo bypass

# ── FastAPI ────────────────────────────────────────────────────
FASTAPI_URL=https://oracle-api.railway.app       # Production
FASTAPI_URL_LOCAL=http://localhost:8000           # Local dev
FASTAPI_SECRET_KEY=...                            # Internal service auth
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,https://oracle.vercel.app

# ── Rate Limiting ──────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=100

# ── Deployment ─────────────────────────────────────────────────
VERCEL_PROJECT_ID=...
RAILWAY_PROJECT_ID=...

# ── Feature Flags ──────────────────────────────────────────────
ORACLE_OFFLINE_MODE=false             # Phase 2 activation
ORACLE_MAX_AGENTS=1000                # Simulation cap
ORACLE_MAX_ROUNDS=40                  # Simulation round cap
ORACLE_SIGNAL_REFRESH_MINUTES=15      # L1-L5 refresh interval
